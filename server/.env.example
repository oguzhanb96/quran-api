# Coolify + Traefik: container often listens on PORT=8080 (see loadbalancer.server.port).
# Local dev: omit PORT or use 8787 — Node falls back to 8787 if PORT unset.
PORT=8080
ADMIN_TOKEN=replace-with-long-random-secret-at-least-32-characters
INVENTORY_READ_TOKEN=replace-with-long-random-secret-at-least-32-characters
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
DATA_DIR=./data
PUBLIC_DIR=./public

# Optional: public API URL for Swagger "Try it out" (if Host / X-Forwarded-* is wrong behind a proxy)
# PUBLIC_API_BASE=https://your-domain.example
